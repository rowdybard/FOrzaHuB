# Copy to .env.local for local dev, and add these as environment variables
# in the Cloudflare Pages dashboard (Settings -> Environment variables).
#
# Found in Supabase: Project Settings -> API.
# The anon key is safe to expose in the browser — access is controlled by
# Row-Level Security (RLS) policies, NOT by hiding this key.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# When unset, the app falls back to local mock data (src/data/mock.js).
