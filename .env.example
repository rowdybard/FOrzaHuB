# Copy to .env.local for local dev, and add these as environment variables
# in Cloudflare Pages (Settings -> Environment variables).
#
# Found in Supabase: Project Settings -> API / Connect dialog.
# Use the browser-safe publishable key (`sb_publishable_...`) when available.
# Legacy anon public keys also work. Never use service_role or sb_secret keys
# in this Vite/Cloudflare Pages frontend.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-public-key

# Frontend proof upload limit in megabytes. Defaults to 10 when unset.
# Proof uploads are image-only (PNG, JPG/JPEG, WEBP). Video proof is link-only.
VITE_MAX_PROOF_UPLOAD_MB=10

# When unset, the app falls back to local mock data (src/data/mock.js).
#
# Discord login setup (one-time): see docs/auth.md
